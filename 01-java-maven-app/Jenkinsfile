def gv

pipeline {
    agent any

    tools { // Make maven available for build stage
        maven 'maven-3.9'
    }

    stages {
        stage('init') {
            steps {
                script {
                    dir('01-java-maven-app') { // Load from 01-java-maven-app directory
                        gv = load "script.groovy"
                    }
                }
            }
        }
        stage('Build jar') {
            steps {
                script {
                    gv.buildJar()
                }
            }
        }
        stage('Build docker image') {
            steps {
                script {
                    gv.buildImage()
                }
            }
        }
        stage('Deploy') {
            steps {
                script {
                    gv.deployApp()
                }
            }
        }
    }
}
